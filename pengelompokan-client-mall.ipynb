# 1. Import Library
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans

# 2. Memuat Dataset
url = "https://raw.githubusercontent.com/vjchoudhary7/Customer-Segmentation-Tutorial-in-python/master/Mall_Customers.csv"
df = pd.read_csv(url)

# Kita hanya ambil kolom Pendapatan (Income) dan Skor Pengeluaran (Spending Score)
X = df.iloc[:, [3, 4]].values 

# 3. Mencari Jumlah Cluster Optimal (Metode Elbow)
# Kita mencoba jumlah cluster dari 1 sampai 10
wcss = []
for i in range(1, 11):
    kmeans = KMeans(n_estimators='warn', n_clusters=i, init='k-means++', random_state=42)
    kmeans.fit(X)
    wcss.append(kmeans.inertia_)

# Visualisasi Elbow Method
plt.plot(range(1, 11), wcss, marker='o')
plt.title('Metode Elbow untuk Menentukan Jumlah Cluster')
plt.xlabel('Jumlah Cluster')
plt.ylabel('WCSS (Error)')
plt.show()

# 4. Menjalankan K-Means dengan Cluster Optimal (Misal: 5)
kmeans = KMeans(n_clusters=5, init='k-means++', random_state=42)
y_kmeans = kmeans.fit_predict(X)

# 5. Visualisasi Hasil Clustering
plt.figure(figsize=(10, 7))
plt.scatter(X[y_kmeans == 0, 0], X[y_kmeans == 0, 1], s=100, c='red', label='Hemat (Low Spend)')
plt.scatter(X[y_kmeans == 1, 0], X[y_kmeans == 1, 1], s=100, c='blue', label='Rata-rata')
plt.scatter(X[y_kmeans == 2, 0], X[y_kmeans == 2, 1], s=100, c='green', label='Sultan (High Income & Spend)')
plt.scatter(X[y_kmeans == 3, 0], X[y_kmeans == 3, 1], s=100, c='cyan', label='Impulsif (Low Income, High Spend)')
plt.scatter(X[y_kmeans == 4, 0], X[y_kmeans == 4, 1], s=100, c='magenta', label='Kikir (High Income, Low Spend)')

# Menampilkan Centroid (Titik Pusat Cluster)
plt.scatter(kmeans.cluster_centers_[:, 0], kmeans.cluster_centers_[:, 1], s=300, c='yellow', label='Centroids')
plt.title('Segmentasi Pelanggan Mall')
plt.xlabel('Pendapatan Tahunan (k$)')
plt.ylabel('Skor Pengeluaran (1-100)')
plt.legend()
plt.show()
